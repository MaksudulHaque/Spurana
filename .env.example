# Spurana ✦ Environment variables
#
# Copy this file to `.env` for local testing (with Vercel CLI),
# OR set these directly in Vercel Dashboard → Project → Settings → Environment Variables.
#
# `.env` is gitignored — your real keys never get committed.

# ── Anthropic API key (optional) ─────────────────────────────────
# If unset, users can paste their own key in the app:
#   Sanctuary → Settings → Global Settings → 🔑 Anthropic API Key
#
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-PASTE-YOUR-KEY-HERE
