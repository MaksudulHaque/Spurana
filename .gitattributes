# Spurana ✦ Git attributes
# Normalize line endings — critical for Windows → Vercel Linux

* text=auto eol=lf

*.html       text eol=lf
*.js         text eol=lf
*.css        text eol=lf
*.json       text eol=lf
*.md         text eol=lf
*.toml       text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.sh         text eol=lf

*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.ico        binary
*.svg        text eol=lf
*.woff       binary
*.woff2      binary
*.ttf        binary
*.otf        binary
*.zip        binary
*.pdf        binary
*.mp3        binary
*.mp4        binary
*.webm       binary

index.html linguist-detectable=true
index.html linguist-language=HTML
